{
  "name": "whatsapp-mcp-server",
  "version": "1.0.0",
  "license": "MIT",
  "description": "WhatsApp MCP Server - Electron app exposing WhatsApp messaging via Model Context Protocol",
  "main": "dist/main.js",
  "homepage": "./",
  "scripts": {
    "start": "npm run dev",
    "dev": "npm run build:main && node scripts/dev.mjs",
    "build": "npm run build:main && npm run build:renderer && electron-builder",
    "build:main": "tsc --project tsconfig.main.json && esbuild 'dist/**/*.js' --platform=node --format=cjs --outdir=dist --allow-overwrite && cp assets/icon.png dist/icon.png && electron-rebuild -f -w better-sqlite3",
    "build:renderer": "vite build",
    "type-check": "tsc --noEmit",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest",
    "preview": "vite preview",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "electron-settings": "^4.0.2",
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^38.0.0",
    "electron-builder": "^26.7.0",
    "esbuild": "^0.27.3",
    "semantic-release": "^25.0.3",
    "typescript": "^5.3.0",
    "vite": "^8.0.8",
    "vitest": "^4.0.18",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.clementpang.whatsapp-mcp-server",
    "productName": "WhatsApp MCP Server",
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "publish": {
      "provider": "github",
      "owner": "panghy",
      "repo": "whatsapp-mcp-server"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "6947A73B2N"
      }
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Network"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    }
  },
  "overrides": {
    "@electron/asar": "^4.0.0",
    "global-agent": "^4.0.0",
    "cacache": "^20.0.0",
    "rimraf": "^6.0.0",
    "glob": "^13.0.0"
  }
}
